# Entorno
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/gestionthibe
# MONGO_DB_NAME=gestionthibe
# MONGO_USER=
# MONGO_PASSWORD=
# MONGO_AUTH_SOURCE=admin
# MONGO_AUTH_MECHANISM=SCRAM-SHA-256
# MONGO_TLS=false
# MONGO_TLS_CA_FILE=

# Seguridad / SaaS
# En producción debe ser un secreto largo, aleatorio y privado.
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=604800
# Lista separada por comas con los dominios permitidos para el frontend SaaS.
CORS_ORIGINS=http://localhost:5173,https://app.example.com
# Activar cuando la API corre detrás de un proxy/load balancer que termina TLS.
TRUST_PROXY=false

# Administrador inicial
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password
