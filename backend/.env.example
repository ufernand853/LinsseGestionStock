# Entorno
NODE_ENV=development
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017/gestionthibe
# MONGO_DB_NAME=gestionthibe
# MONGO_USER=
# MONGO_PASSWORD=
# MONGO_AUTH_SOURCE=admin
# MONGO_AUTH_MECHANISM=SCRAM-SHA-256
# MONGO_TLS=false
# MONGO_TLS_CA_FILE=

# Seguridad / SaaS
# En producción debe ser un secreto largo, aleatorio y privado.
JWT_SECRET=replace-with-a-long-random-secret
ACCESS_TOKEN_TTL=3600
REFRESH_TOKEN_TTL=604800
# Lista separada por comas con los dominios permitidos para el frontend SaaS.
CORS_ORIGINS=http://localhost:5173,https://app.example.com
# Activar cuando la API corre detrás de un proxy/load balancer que termina TLS.
TRUST_PROXY=false

# Administrador inicial
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# URL pública de la app usada para construir callbacks de Mercado Pago.
PUBLIC_APP_URL=https://app.example.com

# Mercado Pago Uruguay / suscripciones en pesos uruguayos.
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_COUNTRY=UY
MERCADOPAGO_CURRENCY=UYU
MERCADOPAGO_SUCCESS_URL=https://app.example.com/pago/exitoso
MERCADOPAGO_PENDING_URL=https://app.example.com/pago/pendiente
MERCADOPAGO_FAILURE_URL=https://app.example.com/pago/error
MERCADOPAGO_NOTIFICATION_URL=https://app.example.com/api/webhooks/mercadopago
